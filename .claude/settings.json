{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "loopcoder hook conductor-reporter",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "loopcoder hook conductor-relay-guard",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash|PowerShell|pwsh"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "loopcoder hook conductor-reporter",
            "timeout": 10,
            "type": "command"
          },
          {
            "command": "loopcoder hook conductor-relay-guard",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ]
  }
}
